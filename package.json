{
  "name": "skyguard-js",
  "version": "1.2.3",
  "description": "A lightweight, dependency-free TypeScript backend framework",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "typescript",
    "javascript",
    "node",
    "nodejs",
    "express",
    "nestjs",
    "framework",
    "library",
    "backend",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Pipe930/Skyguard-js"
  },
  "bugs": {
    "url": "https://github.com/Pipe930/Skyguard-js/issues"
  },
  "homepage": "https://pipe930.github.io/skyguard-documentation/",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "scripts": {
    "exec": "ts-node examples/main.ts",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,tests}/**/*.ts\"",
    "dev": "NODE_ENV=development nodemon examples/main.ts",
    "test": "NODE_ENV=test jest --verbose",
    "test:watch": "jest --watch --onlyChanged",
    "test:cov": "jest --coverage",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "author": {
    "name": "Pipe930",
    "url": "https://github.com/Pipe930"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.3.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "jest": "30.3.0",
    "nodemon": "3.1.14",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2"
  }
}
